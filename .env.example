# Public API base URL used by src/api/studioApi.js.
# Leave empty to use same-origin relative paths.
VITE_API_BASE_URL=

# Optional Vite dev server port.
VITE_DEV_PORT=5174

# Optional Vite dev proxy target for /api, /init and /stream.
# Set this when your backend runs on a different local port in development.
VITE_DEV_PROXY_TARGET=http://localhost:8087
